{
  "name": "fill-webui",
  "version": "0.0.1",
  "scripts": {
    "dev": "vite dev",
    "devProdServer": "VITE_USE_PROD_ENDPOINT=true vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "codegen": "USE_PROD_ENDPOINT=true graphql-codegen",
    "codegenDev": "graphql-codegen"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.0",
    "@graphql-codegen/cli": "^6.1.1",
    "@graphql-codegen/client-preset": "^5.2.2",
    "@iconify-json/lucide": "^1.2.89",
    "@iconify/tailwind4": "^1.2.1",
    "@internationalized/date": "^3.11.0",
    "@lucide/svelte": "^0.563.1",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-cloudflare": "^7.2.6",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.1.18",
    "bits-ui": "^2.15.5",
    "clsx": "^2.1.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.3.0",
    "graphql": "^16.12.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.49.2",
    "svelte-check": "^4.3.6",
    "svelte2tsx": "^0.7.47",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1"
  },
  "private": true,
  "type": "module",
  "dependencies": {
    "@urql/exchange-graphcache": "^9.0.0",
    "@urql/svelte": "^5.0.0",
    "mode-watcher": "^1.1.0",
    "runed": "^0.37.1"
  }
}
