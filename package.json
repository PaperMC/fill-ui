{
  "name": "fill-webui",
  "version": "0.0.1",
  "scripts": {
    "dev": "vite dev",
    "devProdServer": "VITE_USE_PROD_ENDPOINT=true vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "codegen": "USE_PROD_ENDPOINT=true graphql-codegen",
    "codegenDev": "graphql-codegen"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/client-preset": "^6.0.0",
    "@iconify-json/lucide": "^1.2.115",
    "@iconify/tailwind4": "^1.2.3",
    "@internationalized/date": "^3.12.2",
    "@lucide/svelte": "^1.23.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/kit": "^2.69.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.2",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "graphql": "^16.14.2",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn-svelte": "^1.3.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "svelte2tsx": "^0.7.57",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3"
  },
  "private": true,
  "type": "module",
  "dependencies": {
    "@urql/exchange-graphcache": "^9.0.1",
    "@urql/svelte": "^5.0.0",
    "mode-watcher": "^1.1.0",
    "runed": "^0.37.1"
  }
}
